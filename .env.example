DATABASE_URL=postgresql://user@localhost:5432/aiagent
# Generieren mit: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=changeme
# "production" deaktiviert /docs, /redoc, /openapi.json. In Render auf
# ENVIRONMENT=production setzen; lokal leer lassen oder "development".
ENVIRONMENT=development
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_PRO_MONTHLY=price_xxx
STRIPE_PRICE_ID_PRO_YEARLY=price_xxx
STRIPE_SUCCESS_URL=http://localhost:5173/app/billing/success
STRIPE_CANCEL_URL=http://localhost:5173/app/billing/cancel
# Stripe Tax erst aktivieren, wenn im Stripe-Dashboard eingerichtet (Steuerregistrierung)
STRIPE_AUTOMATIC_TAX=false

EMAIL_FROM=noreply@example.com
# Versand über die Resend HTTP-API (https://resend.com), siehe
# api/services/email_service.py. Ersetzt Gmail-SMTP, das auf Render mit
# "Network is unreachable" fehlschlug. EMAIL_FROM muss zu einer in Resend
# verifizierten Domain gehören, sonst lehnt Resend den Versand ab.
RESEND_API_KEY=re_changeme
# Empfänger fürs Support-Kontaktformular (optional, Standard s.u.)
SUPPORT_EMAIL=gecenanalysis@gmail.com

FRONTEND_URL=http://127.0.0.1:5173
# In Produktion: die echte Vercel-Domain des Frontends (nicht die eigene
# Backend-URL - CORS_ORIGINS sind die Origins, die die API aufrufen dürfen).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: Error-Tracking (leer = deaktiviert)
SENTRY_DSN=

ALPHA_VANTAGE_API_KEY=changeme
FRED_API_KEY=changeme
SIMFIN_API_KEY=changeme

# Optional: Verzeichnis für den DataLoader-Dateicache (Standard: ./cache).
# Läuft auf Render im ephemeren Container-Dateisystem (Free-Plan hat kein
# Persistent Disk) - überlebt Deploys daher nur zusammen mit den
# CACHE_S3_*-Vars unten. Lokal einfach leer lassen.
CACHE_DIR=cache

# Optional: S3-kompatibler Objektspeicher als persistente Zweitkopie des
# Datei-Caches (siehe agent/cache_object_storage.py). Ohne diese vier Werte
# ist der Sync ein No-op - lokal bewusst leer lassen. Konfiguriert für
# Backblaze B2 (10 GB/Monat kostenlos, kein Kreditkarten-Zwang für private
# Buckets - im Unterschied zu Cloudflare R2). Bucket + "Application Key"
# (auf genau diesen einen Bucket beschränkt, nicht "All buckets") im
# Backblaze-Dashboard unter B2 Cloud Storage anlegen; CACHE_S3_ENDPOINT_URL
# ist der "S3 Endpoint" von der Bucket-Detailseite, z. B.
# s3.us-west-004.backblazeb2.com (Schema s3.<region>.backblazeb2.com - die
# Region wird daraus automatisch abgeleitet).
CACHE_S3_ENDPOINT_URL=
CACHE_S3_ACCESS_KEY_ID=
CACHE_S3_SECRET_ACCESS_KEY=
CACHE_S3_BUCKET_NAME=
