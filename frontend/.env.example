# Lokal: http://127.0.0.1:8000
# Auf Vercel (Projekt-Env-Var setzen): URL des Render-Backends, z. B.
# https://fundamental-analysis-agent-9.onrender.com — und diese Domain in
# CORS_ORIGINS auf dem Backend (Render-Env) ergänzen.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Build-Zeit-Variable (kein VITE_-Präfix — wird von scripts/generate-glossary.ts
# per plain Node/tsx gelesen, nicht über import.meta.env) für die SEO-
# Metadaten des Kennzahlen-Glossars (canonical-Links, sitemap.xml). Muss beim
# Produktions-Build auf die echte Domain gesetzt werden, z. B.:
# SITE_URL=https://comanalysis.app npm run build
SITE_URL=https://example.com

# Plausible Analytics (EU/self-hosted, cookielos) — leer lassen, um Analytics
# komplett zu deaktivieren (z. B. lokale Entwicklung). Das Script laedt erst,
# nachdem der Nutzer im Cookie-Banner zugestimmt hat (siehe
# CookieConsentBanner.tsx / lib/plausible.ts).
VITE_PLAUSIBLE_DOMAIN=
VITE_PLAUSIBLE_API_HOST=https://plausible.io
