# Lokal: http://127.0.0.1:8000
# Auf Render Static Site (Projekt-Env-Var setzen): URL des Render-Backends,
# z. B. https://fundamental-analysis-agent-9.onrender.com — und diese Domain
# in CORS_ORIGINS auf dem Backend (Render-Env) ergänzen.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Build-Zeit-Variable (kein VITE_-Präfix — wird von scripts/generate-glossary.ts
# per plain Node/tsx gelesen, nicht über import.meta.env) für die SEO-
# Metadaten des Kennzahlen-Glossars (canonical-Links, sitemap.xml). Muss beim
# Produktions-Build auf die echte Domain gesetzt werden, z. B.:
# SITE_URL=https://comanalysis.app npm run build
SITE_URL=https://example.com

# Sentry Error-Tracking (Frontend) — leer lassen, um es lokal zu deaktivieren.
VITE_SENTRY_DSN=

# Cloudflare Web Analytics (kostenlos, cookielos) — leer lassen, um Analytics
# komplett zu deaktivieren (z. B. lokale Entwicklung). Das Script laedt erst,
# nachdem der Nutzer im Cookie-Banner zugestimmt hat (siehe
# CookieConsentBanner.tsx / lib/webAnalytics.ts). Token kommt aus dem
# Cloudflare-Dashboard (Analytics & Logs -> Web Analytics -> Add a site ->
# JavaScript-Snippet-Methode).
VITE_CF_BEACON_TOKEN=
